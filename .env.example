# Database connection string — Local Offline Postgres via Docker
DATABASE_URL="postgresql://fitbit_user:fitbit_pass@localhost:5432/fitbit_db"

# Local Data Source Path
FITBIT_DATA_DIR="./"

# Timezone of the Fitbit WEARER (not the machine running the script).
# Used for correct sleep date attribution in queries.
# This must be set to match the timezone of the person whose data is tracked.
# Examples: Asia/Kolkata | America/Los_Angeles | America/New_York | Europe/London
FITBIT_USER_TIMEZONE="Asia/Kolkata"

# ──────────────────────────────────────────────────────────
# Fitbit API credentials (for ongoing sync via sync.js)
# Register a "Personal" app at https://dev.fitbit.com/apps/new
#   - OAuth 2.0 Application Type: Personal
#   - Redirect URI: http://localhost:8000/callback
# ──────────────────────────────────────────────────────────
FITBIT_CLIENT_ID="your_client_id"
FITBIT_CLIENT_SECRET="your_client_secret"

# These are auto-populated when you run: node fitbit_auth.js
FITBIT_ACCESS_TOKEN=
FITBIT_REFRESH_TOKEN=
